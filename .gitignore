# Xcode project is generated by XcodeGen from project.yml — regenerate, don't commit.
*.xcodeproj/
*.xcworkspace/
!default.xcworkspace

# Xcode / SwiftPM build artifacts
.build/
DerivedData/
build/
*.xcuserstate
xcuserdata/
.swiftpm/
Package.resolved

# Secrets — HERC-010: client_id/client_secret/member-id seed the Keychain on
# first run. Never commit the real secret. Commit Secrets.example.plist instead.
Secrets.plist
App/Secrets.plist

# macOS
.DS_Store
