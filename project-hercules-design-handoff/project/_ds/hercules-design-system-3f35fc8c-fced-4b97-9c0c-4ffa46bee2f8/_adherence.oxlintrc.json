{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/navigation/**",
              "components/viz/**",
              "ui_kits/hercules-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Azeret Mono))/i]",
        "message": "Font not provided by the design system. Available: Azeret Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BarStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:bars|height|gateStart|gateWidth|marker|animate|footer|style|key|ref|className|style|children)$/]",
        "message": "<BarStrip> doesn't accept that prop. Declared props: bars, height, gateStart, gateWidth, marker, animate, footer, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|trailingIcon|disabled|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, trailingIcon, disabled, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|eyebrow|sublabel|tone|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, eyebrow, sublabel, tone, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:deep|card|flat)$/]",
        "message": "<Card> tone must be one of 'deep' | 'card' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataDomainItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:glyph|label|sublabel|state|onClick|style|key|ref|className|style|children)$/]",
        "message": "<DataDomainItem> doesn't accept that prop. Declared props: glyph, label, sublabel, state, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataDomainItem'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:connected|drill)$/]",
        "message": "<DataDomainItem> state must be one of 'connected' | 'drill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogoMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|style|key|ref|className|style|children)$/]",
        "message": "<LogoMark> doesn't accept that prop. Declared props: size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OversizedScore'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|classification|classTone|size|style|key|ref|className|style|children)$/]",
        "message": "<OversizedScore> doesn't accept that prop. Declared props: value, unit, classification, classTone, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OversizedScore'] > JSXAttribute[name.name='classTone'] > Literal[value!=/^(?:accent|muted)$/]",
        "message": "<OversizedScore> classTone must be one of 'accent' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|ticks|stat|state|key|ref|className|style|children)$/]",
        "message": "<ProgressRow> doesn't accept that prop. Declared props: name, ticks, stat, state."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRow'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:done|active|idle)$/]",
        "message": "<ProgressRow> state must be one of 'done' | 'active' | 'idle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScreenHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|onBack|toggle|style|key|ref|className|style|children)$/]",
        "message": "<ScreenHeader> doesn't accept that prop. Declared props: title, subtitle, onBack, toggle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedToggle> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|size|flex|key|ref|className|style|children)$/]",
        "message": "<StatCell> doesn't accept that prop. Declared props: label, value, unit, size, flex."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|tone|live|style|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: children, variant, tone, live, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:class|filled|live)$/]",
        "message": "<StatusPill> variant must be one of 'class' | 'filled' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|muted)$/]",
        "message": "<StatusPill> tone must be one of 'accent' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendChart'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|target|max|label|avg|height|style|key|ref|className|style|children)$/]",
        "message": "<TrendChart> doesn't accept that prop. Declared props: data, target, max, label, avg, height, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
